<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Toast.Maui.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="14">

            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="Toast — Toast Playground" />

            <Label
                FontSize="13"
                HorizontalOptions="Center"
                Opacity="0.7"
                Text="Nhấn các nút bên dưới để thử các kiểu toast." />

            <Button
                BackgroundColor="#2E7D4F"
                Command="{Binding ShowSuccessCommand}"
                Text="Success (Top)"
                TextColor="White" />

            <Button
                BackgroundColor="#C0392B"
                Command="{Binding ShowErrorCommand}"
                Text="Error (Bottom)"
                TextColor="White" />

            <Button
                BackgroundColor="#D98E00"
                Command="{Binding ShowWarningCommand}"
                Text="Warning (Center)"
                TextColor="White" />

            <Button
                BackgroundColor="#2F5EA8"
                Command="{Binding ShowInfoCommand}"
                Text="Info (Top)"
                TextColor="White" />

            <Button
                BackgroundColor="#512BD4"
                Command="{Binding ShowActionCommand}"
                Text="With Action (Undo)"
                TextColor="White" />

            <Button
                BackgroundColor="#333"
                Command="{Binding ShowQueueCommand}"
                Text="Stack 4 Toasts (Top + Bottom)"
                TextColor="White" />

            <Button
                BackgroundColor="#333"
                Command="{Binding ShowPopupCommand}"
                Text="Show Popup test"
                TextColor="White" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
